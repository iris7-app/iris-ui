{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "expand",
  "entryPoints": ["../src/app"],
  "tsconfig": "../tsconfig.app.json",
  "out": "../docs/typedoc",
  "name": "Iris UI — TypeScript API Docs",
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "excludeNotDocumented": false,
  "includeVersion": true,
  "navigationLinks": {
    "GitLab": "https://gitlab.com/iris-7/iris-ui",
    "Backend API": "https://iris7.duckdns.org/swagger-ui.html"
  },
  "logLevel": "Warn",
  "treatWarningsAsErrors": false,
  "compilerOptions": {
    "skipLibCheck": true
  }
}
